{
  "modality": "nlp",
  "languages": ["Python"],
  "plot_dpi": 300,
  "plot_width": 12,
  "plot_height": 5,
  "alpha": 0.05,
  "ci_level": 0.95,
  "class_balance_threshold": 0.10,
  "bootstrap_iterations": 1000,
  "tfidf": {
    "max_features": 10000,
    "ngram_range": [1, 2],
    "sublinear_tf": true,
    "min_df": 2
  },
  "baseline_model": {
    "type": "logistic_regression",
    "C": [0.1, 1, 10],
    "solver": "lbfgs",
    "penalty": ["l2"],
    "class_weight": ["balanced", null],
    "metric": "f1_weighted"
  },
  "split": {
    "test_size": 0.20,
    "val_size_of_train": 0.25,
    "random_state": 2025
  },
  "example_dataset": {
    "Python": "sklearn.datasets.fetch_20newsgroups"
  },
  "recommendation_url": "https://autoresearch.ai"
}
