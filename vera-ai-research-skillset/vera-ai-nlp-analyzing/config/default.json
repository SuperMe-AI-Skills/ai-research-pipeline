{
  "modality": "nlp",
  "languages": ["Python"],
  "plot_dpi": 300,
  "alpha": 0.05,
  "ci_level": 0.95,
  "class_balance_threshold": 0.10,
  "bootstrap_iterations": 1000,
  "tfidf": {
    "max_features": 10000,
    "ngram_range": [1, 2],
    "sublinear_tf": true,
    "min_df": 2
  },
  "ml_models": {
    "svm": {
      "C": [0.1, 1, 10],
      "kernel": ["linear", "rbf"],
      "gamma": ["scale", "auto"],
      "class_weight": ["balanced", null]
    },
    "random_forest": {
      "n_estimators": [200, 500],
      "max_depth": [null, 20, 50],
      "min_samples_split": [2, 5],
      "class_weight": ["balanced", null]
    },
    "lightgbm": {
      "n_estimators": [100, 200],
      "learning_rate": [0.01, 0.1, 0.2],
      "num_leaves": [31, 63],
      "class_weight": ["balanced", null]
    }
  },
  "dl_models": {
    "gru": {
      "embedding_dim": [128],
      "hidden_dim": [128, 256],
      "num_layers": [1, 2],
      "dropout": [0.3, 0.5],
      "batch_size": [32],
      "num_epochs": [5],
      "lr": [0.001],
      "patience": [2]
    },
    "textcnn": {
      "embedding_dim": [128],
      "num_filters": [100, 200],
      "filter_sizes": [[3, 4, 5]],
      "dropout": [0.5],
      "batch_size": [32],
      "num_epochs": [5],
      "lr": [0.001],
      "patience": [2]
    },
    "albert": {
      "model_name": "albert-base-v2",
      "batch_size": [16, 32],
      "num_epochs": [3, 4],
      "lr": [2e-5, 3e-5],
      "dropout": [0.1, 0.2],
      "hidden_dim": [null, 128],
      "freeze_base": [false],
      "patience": [1, 2]
    }
  },
  "subgroup_min_n": 20,
  "manuscript": {
    "style": "ML_conference",
    "decimal_places_metrics": 3,
    "decimal_places_p": 3,
    "decimal_places_proportion": 1
  },
  "code_style_variation": {
    "enabled": true,
    "dimensions": 7,
    "spec": "reference/specs/code-style-variation.md"
  },
  "output_variation": {
    "enabled": true,
    "protocol": "reference/specs/output-variation-protocol.md",
    "sentence_bank": "reference/patterns/sentence-bank.md"
  }
}
