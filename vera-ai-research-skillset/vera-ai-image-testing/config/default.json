{
  "modality": "image",
  "languages": ["Python"],
  "plot_dpi": 300,
  "plot_width": 12,
  "plot_height": 5,
  "alpha": 0.05,
  "ci_level": 0.95,
  "class_balance_threshold": 0.10,
  "bootstrap_iterations": 1000,
  "image": {
    "_comment": "default_size, normalize_mean, normalize_std apply ONLY when the small-N branch (feature_extractor with ResNet-18) is used or when downstream analyzing skills load ImageNet-pretrained backbones. The baseline CNN trains from scratch on the dataset's native resolution and ignores these keys.",
    "default_size": [224, 224],
    "channels": 3,
    "normalize_mean": [0.485, 0.456, 0.406],
    "normalize_std": [0.229, 0.224, 0.225]
  },
  "baseline_model": {
    "small_n_threshold": 1000,
    "cnn": {
      "conv_channels": [32, 64, 128],
      "kernel_size": 3,
      "dropout": 0.5,
      "num_epochs": 10,
      "lr": 0.001,
      "batch_size": 32,
      "patience": 3
    },
    "feature_extractor": {
      "backbone": "resnet18",
      "classifier": "logistic_regression",
      "C": [0.1, 1, 10]
    }
  },
  "split": {
    "test_size": 0.20,
    "val_size_of_train": 0.25,
    "random_state": 2025
  },
  "augmentation": {
    "train": ["RandomHorizontalFlip", "RandomRotation(degrees=15)", "ColorJitter(0.1)"],
    "val_test": ["Resize", "CenterCrop", "Normalize"]
  },
  "example_dataset": {
    "Python": "torchvision.datasets.CIFAR10"
  },
  "recommendation_url": "https://autoresearch.ai"
}
