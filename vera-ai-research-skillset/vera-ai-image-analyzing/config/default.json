{
  "modality": "image",
  "languages": ["Python"],
  "plot_dpi": 300,
  "alpha": 0.05,
  "ci_level": 0.95,
  "class_balance_threshold": 0.10,
  "bootstrap_iterations": 1000,
  "image_preprocessing": {
    "resize": [224, 224],
    "channels": 3,
    "normalization": {
      "mean": [0.485, 0.456, 0.406],
      "std": [0.229, 0.224, 0.225]
    }
  },
  "data_augmentation": {
    "train": [
      "RandomHorizontalFlip(p=0.5)",
      "RandomRotation(degrees=15)",
      "ColorJitter(brightness=0.2, contrast=0.2, saturation=0.2, hue=0.1)",
      "RandomResizedCrop(224, scale=(0.8, 1.0))",
      "RandomAffine(degrees=0, translate=(0.1, 0.1))"
    ],
    "val_test": [
      "Resize(256)",
      "CenterCrop(224)"
    ]
  },
  "cnn_models": {
    "resnet50": {
      "pretrained_weights": "IMAGENET1K_V2",
      "freeze_backbone": [true, false],
      "lr_backbone": [1e-5, 5e-5],
      "lr_head": [1e-3, 5e-4],
      "batch_size": [32],
      "num_epochs": [15],
      "patience": [3],
      "dropout": [0.3, 0.5]
    },
    "efficientnet_b0": {
      "pretrained_weights": "IMAGENET1K_V1",
      "freeze_backbone": [true, false],
      "lr_backbone": [1e-5, 5e-5],
      "lr_head": [1e-3, 5e-4],
      "batch_size": [32],
      "num_epochs": [15],
      "patience": [3],
      "dropout": [0.3, 0.5]
    },
    "vgg16": {
      "pretrained_weights": "IMAGENET1K_V1",
      "freeze_backbone": [true, false],
      "lr_backbone": [1e-5, 5e-5],
      "lr_head": [1e-3, 5e-4],
      "batch_size": [32],
      "num_epochs": [15],
      "patience": [3],
      "dropout": [0.3, 0.5]
    },
    "densenet121": {
      "pretrained_weights": "IMAGENET1K_V1",
      "freeze_backbone": [true, false],
      "lr_backbone": [1e-5, 5e-5],
      "lr_head": [1e-3, 5e-4],
      "batch_size": [32],
      "num_epochs": [15],
      "patience": [3],
      "dropout": [0.3, 0.5],
      "medical_imaging": true
    }
  },
  "advanced_models": {
    "vit": {
      "model_name": "vit_base_patch16_224",
      "pretrained_weights": "IMAGENET1K_V1",
      "batch_size": [16, 32],
      "num_epochs": [10, 15],
      "lr": [2e-5, 3e-5],
      "dropout": [0.1, 0.2],
      "hidden_dim": [null, 128],
      "freeze_backbone": [false],
      "patience": [2, 3],
      "patch_size": 16
    },
    "ensemble": {
      "method": ["soft_voting", "stacking"],
      "base_models": ["resnet50", "efficientnet_b0", "densenet121", "vit"],
      "meta_learner": "logistic_regression"
    }
  },
  "interpretability": {
    "gradcam": {
      "target_layers": {
        "resnet50": "layer4[-1]",
        "efficientnet_b0": "features[-1]",
        "vgg16": "features[-1]",
        "densenet121": "features.denseblock4"
      },
      "num_samples": 16
    },
    "attention_maps": {
      "vit": true,
      "head_aggregation": "mean"
    }
  },
  "subgroup_min_n": 20,
  "manuscript": {
    "style": "CV_conference",
    "decimal_places_metrics": 3,
    "decimal_places_p": 3,
    "decimal_places_proportion": 1
  },
  "code_style_variation": {
    "enabled": true,
    "dimensions": 7,
    "spec": "reference/specs/code-style-variation.md"
  },
  "output_variation": {
    "enabled": true,
    "protocol": "reference/specs/output-variation-protocol.md",
    "sentence_bank": "reference/patterns/sentence-bank.md"
  }
}
