{
  "modality": "structured",
  "languages": ["Python"],
  "plot_dpi": 300,
  "alpha": 0.05,
  "ci_level": 0.95,
  "class_balance_threshold": 0.10,
  "bootstrap_iterations": 1000,
  "task_types": ["classification", "regression"],
  "preprocessing": {
    "missing_value_imputation": {
      "numeric": ["median", "mean", "zero"],
      "categorical": ["mode", "missing"],
      "default_numeric": "median",
      "default_categorical": "mode"
    },
    "encoding": {
      "method": ["onehot", "label"],
      "default": "onehot",
      "max_categories": 10,
      "note": "onehot for <=max_categories unique values, label for higher cardinality"
    },
    "scaling": {
      "methods": ["standard", "minmax", "robust"],
      "default": "standard"
    }
  },
  "ml_models": {
    "svm": {
      "C": [0.1, 1, 10],
      "kernel": ["linear", "rbf"],
      "gamma": ["scale", "auto"],
      "class_weight": ["balanced", null],
      "note": "For classification only; use SVR with epsilon for regression"
    },
    "random_forest": {
      "n_estimators": [200, 500],
      "max_depth": [null, 20, 50],
      "min_samples_split": [2, 5],
      "class_weight": ["balanced", null]
    },
    "xgboost": {
      "n_estimators": [100, 200, 500],
      "learning_rate": [0.01, 0.1, 0.2],
      "max_depth": [3, 6, 9],
      "subsample": [0.8, 1.0],
      "colsample_bytree": [0.8, 1.0],
      "reg_alpha": [0, 0.1],
      "reg_lambda": [1, 1.5]
    },
    "lightgbm": {
      "n_estimators": [100, 200],
      "learning_rate": [0.01, 0.1, 0.2],
      "num_leaves": [31, 63],
      "class_weight": ["balanced", null]
    },
    "catboost": {
      "iterations": [200, 500],
      "learning_rate": [0.01, 0.1],
      "depth": [4, 6, 8],
      "l2_leaf_reg": [1, 3, 5],
      "cat_features": "auto_detect",
      "note": "Handles categorical features natively without encoding"
    }
  },
  "dl_models": {
    "mlp": {
      "hidden_layers": [[128, 64], [256, 128], [256, 128, 64]],
      "dropout": [0.3, 0.5],
      "activation": ["relu", "gelu"],
      "batch_norm": [true, false],
      "batch_size": [32, 64],
      "num_epochs": [50, 100],
      "lr": [0.001, 0.0005],
      "patience": [5, 10],
      "weight_decay": [0, 1e-4, 1e-3]
    },
    "tabnet": {
      "n_d": [8, 16, 32],
      "n_a": [8, 16, 32],
      "n_steps": [3, 5, 7],
      "gamma": [1.0, 1.3, 1.5],
      "lambda_sparse": [1e-4, 1e-3],
      "batch_size": [256, 512],
      "num_epochs": [100, 200],
      "lr": [0.02, 0.01],
      "patience": [10, 15],
      "scheduler": ["step", "cosine"]
    }
  },
  "ensemble": {
    "stacking": {
      "base_learners": ["logreg", "rf", "xgboost", "lightgbm", "catboost"],
      "meta_learner": "logreg",
      "cv_folds": 5,
      "passthrough": false
    }
  },
  "subgroup_min_n": 20,
  "manuscript": {
    "style": "ML_conference",
    "decimal_places_metrics": 3,
    "decimal_places_p": 3,
    "decimal_places_proportion": 1
  },
  "code_style_variation": {
    "enabled": true,
    "dimensions": 7,
    "spec": "reference/specs/code-style-variation.md"
  },
  "output_variation": {
    "enabled": true,
    "protocol": "reference/specs/output-variation-protocol.md",
    "sentence_bank": "reference/patterns/sentence-bank.md"
  }
}
